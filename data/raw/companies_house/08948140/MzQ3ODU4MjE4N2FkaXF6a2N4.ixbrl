body {
	background: white;
	line-height: 1.2;
}
.break {
	page-break-after: always;
	clear: both;
}
.break, .break *, .pagPrintPageFooter, .pagPrintPageFooter * {
	text-align: center;
}
.continue {
	position: relative;
	height: 0;
	text-align: right;
}
.pageHeader {
	font-weight: bold;
	margin-bottom: 30px;
}
.pagPrintPageFooter {  position: relative;   height: 0; }
.counted .counted .pageHeader, .counted .noncounted .pageHeader {	margin-left: -10mm }
.counted .counted .break, .counted .noncounted .break {	margin-left: -25mm }
.underline {
	border-bottom: 1px solid black;
	padding-bottom: 7px;
}
.sectionName {
	display: none;
}*{font-family: "Verdana", Arial; font-size: 8pt; text-align: left;} #coverPageTitle * {font-size: 10pt;} .pageHeader * { font-size: 10pt} @media print {	a {		color:black;		text-decoration: none;	}}.coverPageHeader {	text-align: right;}td { padding: 0; }#dummyHeaderNode {	padding-bottom: 1px;}#amendingHeader *{	text-align: center;	font-weight: bold;	text-transform: uppercase;}#amendingStatement {	font-weight: bold;	margin-top: 25px;}#coverPageTitle {	text-transform: uppercase;	font-weight: bold;}#coverPageTitle.has-left-margin {	float: left;}#coverPageFirmLogo.has-left-margin {	float: left;}#coverPageClientLogo.has-left-margin {	float: left;}#coverPageTitle * {	text-align: center;}table.reportTable { width: 100%; }
table.reportTable td:first-child { width:100%;}
.noteTextBlock table td { padding: 2px 2px 3px 2px; }
.noteTextBlock table[align='center'] { margin: 0 auto 0 auto; float:none; } 
.noteTextBlock table[align='right'] { margin: 0 0 0 auto; float:none; } 
 
 table.directorsSign td {  width: 40em;  font-weight: normal;  vertical-align: top;  }  
 .role { font-weight: normal; padding-top: 0.5em; } 
 .date-placeholder { 	 font-weight: normal; } 
 .dots {   margin-top: 4em;	border-top: 1px dashed; 	width: 10em;  }  .signedPlace { font-weight: normal;}  
 .signPlace { 	padding: 2em 0 0.5em 0; } 
.tightReportTable table.reportTable td {	min-width: 60px; }table.reportTable td {	min-width: 80px; 	text-align: left; }table.reportTable th {	text-align: center;	vertical-align: top;}table.reportTable td.dummyColumn, table.reportTable th.dummyColumn {	min-width: 5px; }table.reportTable tr.title td {	font-weight: bold;	padding: 15px 5px;}table.reportTable td.subtitle {	font-style: italic;}table.reportTable tr.bold td:first-child,table.reportTable tr.total td:first-child,table.reportTable tr.totalTitle td:first-child,table.reportTable tr.subTotal td:first-child {	font-weight: bold;}table.reportTable tr.totalTitle td,table.reportTable tr.total td {	padding-top: 15px;}table.reportTable td.percent, table.reportTable td.null, table.reportTable td.number {	text-align: center;}table tr.dataAlignedRight td.percent, table tr.dataAlignedRight td.null, table tr.dataAlignedRight td.number, table tr.dataAlignedRight td.shares  {	text-align: right; 	min-width: auto; 	padding-right: 0.7em; }table th.thLeft{ text-align: left; } table.reportTable.investSubsidiaries td.text{ width: 40%; }table.reportTable td.noteNumber {	font-weight: bold;	text-align: center;}table.reportTable td.underlining1 {	border-top: 1px solid black;}table.reportTable td.underlining2 {	border-bottom: 3px double black;}table.reportTable td.money, table.reportTable td.shares {	text-align: right;	white-space: nowrap; }.title {	font-weight: bold;	margin-top: 20px;	text-align: left;}.subtitleBold {	font-weight: bold;	text-align: left;}.titleItalic {	font-weight: bold;	font-style: italic;	margin-top: 20px;	text-align: left;}table.company-information {	width: 100%; }table.company-information td:first-child, #flysheet td:first-child {	width: 30%; }table.directorList td{	padding: 1px;}.blank-line {	height: 1em;}#contents {	margin-top: 40px;}#contents th {	padding-bottom: 20px;}#contents tr td {	padding-bottom: 15px;}#contents tr.title td {	padding-bottom: 20px;}#contents td.contentPageNumber {	text-align: center;}.note-section {	counter-reset: noteitem;	padding-left: 0;}.counterPrefix {	padding-top: 1em;	padding-right: 1em;}.counted, .noncounted {	padding-top: 1em;}.counted .counted, .counted .noncounted {	padding-left: 10mm;}.pageHeader, .pageHeader * {	text-align: center;}.noteTextBlock{	padding-top: 1em;}.notesMarkedList li div.noteTextBlock{	padding-top: 0;}td.money .negative-right-bracket,td.money .positive-right-spacer{	min-width: 0.7em;	display: inline-block;}.notesStartPageToEndPageContainer{	margin-top: 50px;	margin-left: 5px;}.boldText td:first-child{   font-weight: bold;}.notesSubSection{	margin-left: 1em;}.subRow td:first-child{	padding-left: 1em;}.examinerSign{	height: 8em;}th.oneWordPerLine {		text-align: center !important;	vertical-align: bottom;	word-spacing: 100vw;}@media screen {	body.drillable-notes *[data-drillablename*='drillable-note']:hover,	body.drillable-notes *[data-drillablename*='drillable-term']:hover,	body.drillable-notes *[data-drillablename*='drillable-codedescription']:hover,	body.drillable-notes *[data-drillablename*='drillable-element']:hover,	body.drillable-notes *[data-drillablename*='drillable-note']:hover *, 	body.drillable-notes *[data-drillablename*='drillable-term']:hover *, 	body.drillable-notes *[data-drillablename*='drillable-codedescription']:hover *,	body.drillable-notes *[data-drillablename*='drillable-element']:hover *,	body.drillable-notes *[data-drillablename*='drillable-textref']:hover, 	body.drillable-notes *[data-drillablename*='drillable-textref']:hover *, 	body.drillable-notes *[data-drillablename*='drillable-value']:hover 	{		cursor: pointer;		background: #dbaacb;	}	body.drillable-notes:hover *[data-drillablename*='drillable-value'], 	body.drillable-notes:hover *[data-drillablename*='drillable-note'], 	body.drillable-notes:hover *[data-drillablename*='drillable-term'], 	body.drillable-notes:hover *[data-drillablename*='drillable-codedescription'], 	body.drillable-notes:hover *[data-drillablename*='drillable-textref']:hover 	{